pe=\"variables_get\"><field name=\"VAR\" id=\"FbnvD.0%1$yXpsLSbxt{\">scaleFactor</field></block></value></block></value><next><block type=\"variables_set\"><field name=\"VAR\" id=\"(~s.bx|,b?`5t`cC}~]5\">transformZ</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"math_arithmetic\"><field name=\"OP\">MULTIPLY</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"math_arithmetic\"><field name=\"OP\">ADD</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"math_arithmetic\"><field name=\"OP\">MULTIPLY</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\":QBX|LkPBw1Xm,+g#o~P\">relativeX</field></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"%x,zcEu6f.Qa?az#x@8c\">cameraSin</field></block></value></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"math_arithmetic\"><field name=\"OP\">MULTIPLY</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"]`-u1*ZTkRjtAI]}sFf3\">relativeY</field></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"8yyL{;ZRNq6QnaPYT4A_\">cameraCos</field></block></value></block></value></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"FbnvD.0%1$yXpsLSbxt{\">scaleFactor</field></block></value></block></value><next><block type=\"variables_set\"><field name=\"VAR\" id=\"ckcX91/{oI-jCHb`Af}1\">textureU</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"math_modulo\"><value name=\"DIVIDEND\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"math_arithmetic\"><field name=\"OP\">ADD</field><value name=\"A\"><shadow type=\"math_number\" disabled-reasons=\"pxt_automatic_disabled\"><field name=\"NUM\">0</field></shadow><block type=\"math_modulo\"><value name=\"DIVIDEND\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"math_arithmetic\"><field name=\"OP\">MINUS</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"xvqN+*:ja)U;ltdEBgqV\">transformX</field></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"lgUf6PjjHM*,A*m+T2lg\">cameraX</field></block></value></block></value><value name=\"DIVISOR\"><shadow type=\"math_number\"><field name=\"NUM\">1</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"|L)piVHqh9kpsw[#[~uX\">mapWidth</field></block></value></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"|L)piVHqh9kpsw[#[~uX\">mapWidth</field></block></value></block></value><value name=\"DIVISOR\"><shadow type=\"math_number\"><field name=\"NUM\">1</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"|L)piVHqh9kpsw[#[~uX\">mapWidth</field></block></value></block></value><next><block type=\"variables_set\"><field name=\"VAR\" id=\"})QK{vbS+@Pz!$aE3Oo0\">textureV</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"math_modulo\"><value name=\"DIVIDEND\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"math_arithmetic\"><field name=\"OP\">ADD</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"math_modulo\"><value name=\"DIVIDEND\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"math_arithmetic\"><field name=\"OP\">ADD</field><value name=\"A\"><shadow type=\"math_number\" disabled-reasons=\"pxt_automatic_disabled\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"(~s.bx|,b?`5t`cC}~]5\">transformZ</field></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"B`wpf?}Y*qlep~pv^wm]\">cameraZ</field></block></value></block></value><value name=\"DIVISOR\"><shadow type=\"math_number\"><field name=\"NUM\">1</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"8[Ze!:GlD2T3YM-$04;[\">mapHeight</field></block></value></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"8[Ze!:GlD2T3YM-$04;[\">mapHeight</field></block></value></block></value><value name=\"DIVISOR\"><shadow type=\"math_number\"><field name=\"NUM\">1</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"8[Ze!:GlD2T3YM-$04;[\">mapHeight</field></block></value></block></value></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>","main.ts":"let cameraX = 16\nlet cameraY = 6\nlet cameraZ = 16\nlet cameraAngleDegrees = 45\nlet verticalScale = 1.5\nlet texturing = true\nlet cameraMovementEnabled = true\nlet bakedLightingEnabled = true\nlet floorTexturingEnabled = true\nlet viewStepOffset = 0\n\nconst SKY = 12\nconst SHADE_ROW = 1\nconst SHADE_FALLBACK = 15\nconst FOV = 0.88\nconst VPROJ = 25\nconst MAX_STEPS = 64\nconst WALL_HEIGHT = 8\nconst FLOOR_TRANSPARENT_COLOR = 0\n\nlet mapWidth = 64\nlet mapHeight = 64\nlet centerX = 0\nlet centerY = 0\nlet screenH = 0\nlet depthRows = 0\nlet cameraCos = 0\nlet cameraSin = 0\n\nlet heightMap: Image = null\nlet colorMap: Image = null\nlet shader: Image = null\nlet floorTex: Image = null\nlet tmData: tiles.TileMapData = null\nlet tileset: Image[] = null\nlet groundedTiles: Image[] = []\n\nconst flatHeightMap: number[] = []\nconst flatColorMap: number[] = []\nconst flatTileMap: number[] = []\nconst flatIsCollisionWall: boolean[] = []\nconst flatIsGrounded: boolean[] = []\nconst flatTextures: number[][] = []\nconst floorTextureFlat: number[] = []\nconst flatBillboardTex: number[][] = []\n\nlet columnBuf: Buffer = null\nconst shadeLUT: number[] = []\nconst colDepth: number[] = []\nconst sinLUT: number[] = []\nconst cosLUT: number[] = []\n\nlet bgImage: Image = null\n\n// worldY is stored separately so we never touch spr.z (not a real Arcade field)\nclass Billboard {\n    constructor(\n        public spr: Sprite,\n        public flatTex: number[],\n        public worldY: number,\n        public scale: number,\n        public vx: number,\n        public vz: number,\n        public bobAmp: number,\n        public bobSpeed: number,\n        public bobPhase: number,\n        public bobBaseY: number,\n        public follows: number\n    ) { }\n}\nlet billboards: Billboard[] = []\nlet billboardsDirty = true\n\nfunction init_trig_tables() {\n    for (let i = 0; i < 360; i++) {\n        const rad = i * 0.0174532925\n        sinLUT[i] = Math.sin(rad)\n        cosLUT[i] = Math.cos(rad)\n    }\n}\n\nfunction init_grounded_tiles() {\n    groundedTiles = [\n        assets.tile`wall_grounded`\n    ]\n}\n\nfunction flatten_image(img: Image): number[] {\n    const flat: number[] = []\n    const w = img.width, h = img.height\n    for (let ty = 0; ty < h; ty++) {\n        for (let tx = 0; tx < w; tx++) {\n            flat[ty * w + tx] = img.getPixel(tx, ty)\n        }\n    }\n    return flat\n}\n\nfunction cache_world_data() {\n    if (!heightMap || !colorMap) return\n\n    mapWidth = heightMap.width\n    mapHeight = heightMap.height\n\n    for (let i = 0; i < 16; i++) {\n        const s = shader.getPixel(i, SHADE_ROW)\n        shadeLUT[i] = (s == 0 || s == i) ? SHADE_FALLBACK : s\n    }\n\n    if (floorTex) {\n        const flat = flatten_image(floorTex)\n        for (let i = 0; i < flat.length; i++) floorTextureFlat[i] = flat[i]\n    }\n\n    if (tileset) {\n        for (let i = 0; i < tileset.length; i++) {\n            const tex = tileset[i]\n            const flat: number[] = []\n            flatIsGrounded[i] = false\n            if (tex) {\n                for (let ty = 0; ty < 16; ty++) {\n                    for (let tx = 0; tx < 16; tx++) {\n                        flat[(ty << 4) | tx] = tex.getPixel(tx, ty)\n                    }\n                }\n                for (const g of groundedTiles) {\n                    if (!g) continue\n                    let match = true\n                    for (let py = 0; py < 16 && match; py++) {\n                        for (let px2 = 0; px2 < 16 && match; px2++) {\n                            if (g.getPixel(px2, py) != tex.getPixel(px2, py)) match = false\n                        }\n                    }\n                    if (match) flatIsGrounded[i] = true\n                }\n            }\n            flatTextures[i] = flat\n        }\n    }\n\n    for (let z = 0; z < mapHeight; z++) {\n        for (let x = 0; x < mapWidth; x++) {\n            const idx = z * mapWidth + x\n            flatHeightMap[idx] = heightMap.getPixel(x, z)\n            flatColorMap[idx] = colorMap.getPixel(x, z)\n            if (tmData) {\n                flatTileMap[idx] = tmData.getTile(x, z)\n                flatIsCollisionWall[idx] = tmData.isWall(x, z)\n            } else {\n                flatTileMap[idx] = 0\n                flatIsCollisionWall[idx] = false\n            }\n        }\n    }\n}\n\nfunction terrain_height(wx: number, wz: number): number {\n    let cx = (wx | 0) % mapWidth; if (cx < 0) cx += mapWidth\n    let cz = (wz | 0) % mapHeight; if (cz < 0) cz += mapHeight\n    return flatHeightMap[cz * mapWidth + cx] * verticalScale\n}\n\nfunction is_wall(wx: number, wz: number): boolean {\n    let cx = (wx | 0) % mapWidth; if (cx < 0) cx += mapWidth\n    let cz = (wz | 0) % mapHeight; if (cz < 0) cz += mapHeight\n    return flatIsCollisionWall[cz * mapWidth + cx]\n}\n\nfunction add_billboard(spr: Sprite, worldX: number, worldZ: number, floatY: number, scale: number,\n    vx: number, vz: number, bobAmp: number, bobSpeed: number) {\n    spr.setFlag(SpriteFlag.Invisible, true)\n    spr.x = worldX * 16\n    spr.y = worldZ * 16\n    const flat = flatten_image(spr.image)\n    billboards.push(new Billboard(spr, flat, floatY, scale, vx, vz, bobAmp, bobSpeed, 0, floatY, 0))\n    billboardsDirty = true\n}\n\nfunction set_billboard_follows(spr: Sprite, on: number) {\n    for (const bb of billboards) {\n        if (bb.spr == spr) {\n            bb.follows = on\n            if (on && bb.vx == 0 && bb.vz == 0) {\n                bb.vx = 0.07\n                bb.vz = 0.05\n            }\n            return\n        }\n    }\n}\n\nfunction use_tilemap_as_data(tm: tiles.TileMapData) {\n    tiles.setTilemap(tm)\n    const sc = game.currentScene()\n    if (sc.tileMap && sc.tileMap.renderable) {\n        sc.allSprites.removeElement(sc.tileMap.renderable)\n    }\n    tmData = tm\n    tileset = tm.getTileset()\n    cache_world_data()\n}\n\nfunction check_controls() {\n    if (!cameraMovementEnabled) return\n\n    cameraAngleDegrees += controller.dx() * 0.8\n    if (cameraAngleDegrees < 0) cameraAngleDegrees += 360\n    cameraAngleDegrees = cameraAngleDegrees % 360\n    const lutIndex = cameraAngleDegrees | 0\n    cameraCos = cosLUT[lutIndex]\n    cameraSin = sinLUT[lutIndex]\n\n    const moveX = controller.dy() * cameraSin * 0.06\n    const moveZ = controller.dy() * cameraCos * 0.06\n    const r = 0.2\n    const padX = moveX > 0 ? r : -r\n    const padZ = moveZ > 0 ? r : -r\n\n    const currentGround = terrain_height(cameraX, cameraZ)\n    const newX = (moveX != 0 && !is_wall(cameraX + moveX + padX, cameraZ)) ? cameraX + moveX : cameraX\n    const newZ = (moveZ != 0 && !is_wall(cameraX, cameraZ + moveZ + padZ)) ? cameraZ + moveZ : cameraZ\n    const newGround = terrain_height(newX, newZ)\n    if (newGround - currentGround <= 3) {\n        if (newGround > currentGround) {\n            viewStepOffset -= (newGround - currentGround) * verticalScale\n        } else if (newGround < currentGround) {\n            viewStepOffset += (currentGround - newGround) * verticalScale\n        }\n        cameraX = newX\n        cameraZ = newZ\n        billboardsDirty = true\n    }\n    viewStepOffset *= 0.75\n    if (Math.abs(viewStepOffset) < 0.01) viewStepOffset = 0\n\n    if (cameraX < 0) cameraX += mapWidth\n    if (cameraX >= mapWidth) cameraX -= mapWidth\n    if (cameraZ < 0) cameraZ += mapHeight\n    if (cameraZ >= mapHeight) cameraZ -= mapHeight\n\n    if (controller.A.isPressed()) cameraY += 0.1\n    if (controller.B.isPressed()) cameraY -= 0.1\n    if (cameraY < 1) cameraY = 1\n\n    isMoving = controller.dy() != 0\n    if (isMoving) wobblePhase += 0.20\n}\n\nfunction mode_7() {\n    const bg = bgImage\n    const sw = scene.screenWidth()\n    const cosv = cameraCos\n    const sinv = cameraSin\n    const camX = cameraX\n    const camZ = cameraZ\n    const wobble = isMoving ? Math.sin(wobblePhase) * 0.4 : 0\n    const camY = cameraY + terrain_height(cameraX, cameraZ) + wobble + viewStepOffset\n    const mw = mapWidth\n    const mh = mapHeight\n    const vScale = verticalScale\n    const col = columnBuf\n    const hasFloorTex = floorTexturingEnabled && floorTextureFlat.length > 0\n    const camYVP = camY * VPROJ\n\n    const dirX = -sinv, dirZ = -cosv\n    const planeX = -cosv * FOV, planeZ = sinv * FOV\n\n    for (let x = 0; x < sw; x++) {\n        col.fill(SKY, 0, centerY)\n        col.fill(11, centerY, screenH - centerY)\n\n        const camNdc = (x + x) / sw - 1\n        let rayX = dirX + planeX * camNdc\n        let rayZ = dirZ + planeZ * camNdc\n        if (rayX == 0) rayX = 0.0001\n        if (rayZ == 0) rayZ = 0.0001\n\n        let watermark = screenH\n        let firstBand = true\n        let lastDist = MAX_STEPS * 2\n\n        const rxInv = 1 / rayX, rzInv = 1 / rayZ\n        const deltaX = rxInv < 0 ? -rxInv : rxInv\n        const deltaZ = rzInv < 0 ? -rzInv : rzInv\n\n        let mapX = camX | 0, mapZ = camZ | 0\n        const stepX = rayX < 0 ? -1 : 1\n        const stepZ = rayZ < 0 ? -1 : 1\n        let sideDistX = (rayX < 0 ? (camX - mapX) : (mapX + 1 - camX)) * deltaX\n        let sideDistZ = (rayZ < 0 ? (camZ - mapZ) : (mapZ + 1 - camZ)) * deltaZ\n\n        for (let s = 0; s < MAX_STEPS; s++) {\n            let dist = 0, side = 0\n            if (sideDistX < sideDistZ) {\n                dist = sideDistX; sideDistX += deltaX; mapX += stepX; side = 0\n            } else {\n                dist = sideDistZ; sideDistZ += deltaZ; mapZ += stepZ; side = 1\n            }\n            if (dist < 0.1) continue\n            const nextDist = sideDistX < sideDistZ ? sideDistX : sideDistZ\n\n            const perpNear = side == 0\n                ? (mapX - camX + (1 - stepX) / 2) / rayX\n                : (mapZ - camZ + (1 - stepZ) / 2) / rayZ\n            const useDist = perpNear > 0.1 ? perpNear : 0.1\n            const perpRatio = useDist / dist\n            const nextPerp = nextDist * perpRatio\n\n            let cx = mapX % mw; if (cx < 0) cx += mw\n            let cz = mapZ % mh; if (cz < 0) cz += mh\n            const mapIdx = cz * mw + cx\n\n            const rawH = flatHeightMap[mapIdx]\n            const rawC = flatColorMap[mapIdx]\n\n            const isHole = rawC == FLOOR_TRANSPARENT_COLOR\n            if (isHole && !flatTileMap[mapIdx]) {\n                if (hasFloorTex && watermark > 0) {\n                    let hFar = (centerY + camYVP / nextPerp) | 0\n                    if (hFar < 0) hFar = 0\n                    if (hFar >= screenH) hFar = screenH - 1\n                    if (hFar < watermark) {\n                        for (let y = hFar; y < watermark; y++) {\n                            const fd = camYVP / (y - centerY)\n                            const fwx = camX + rayX * fd\n                            const fwz = camZ + rayZ * fd\n                            const fTexX = ((fwx * 16) | 0) & 15\n                            const fTexY = ((fwz * 16) | 0) & 15\n                            let fp = floorTextureFlat[(fTexY << 4) | fTexX]\n                            if (bakedLightingEnabled && fd > 12) fp = shadeLUT[fp]\n                            col[y] = fp\n                        }\n                        watermark = hFar\n                    }\n                }\n                firstBand = false\n                continue\n            }\n\n            const tileIdx = flatTileMap[mapIdx]\n            let h = rawH\n            const hasTile = tileIdx != 0\n            if (hasTile && flatIsGrounded[tileIdx]) h += WALL_HEIGHT\n\n            const ht = (camY - h * vScale) * VPROJ\n\n            let top = (centerY + ht / useDist) | 0\n            let topFar = (centerY + ht / nextPerp) | 0\n            if (top < 0) top = 0\n            if (topFar < 0) topFar = 0\n            if (topFar > top) topFar = top\n\n            const c = rawC\n            const topColor = bakedLightingEnabled ? shadeLUT[c] : c\n            let faceColor = c\n            if (side == 1 && bakedLightingEnabled) faceColor = (x & 1) ? shadeLUT[c] : c\n\n            if (top < watermark) {\n                if (texturing && !firstBand && hasTile && flatTextures[tileIdx] && flatTextures[tileIdx].length > 0) {\n                    let wallX = side == 0 ? camZ + useDist * rayZ : camX + useDist * rayX\n                    wallX -= Math.floor(wallX)\n                    let texX = (wallX * 16) | 0\n                    if (texX >= 16) texX = 15\n\n                    const topU = centerY + ht / useDist\n                    const baseU = centerY + (camY * VPROJ) / useDist\n                    const fullSpan = baseU - topU\n                    if (fullSpan > 0) {\n                        const stepPerRow = (16 << 8) / fullSpan\n                        let accum = ((top - topU) * stepPerRow) | 0\n                        if (accum < 0) accum = 0\n                        const cachedTex = flatTextures[tileIdx]\n                        const shadeFull = bakedLightingEnabled && useDist > 12\n                        const shadeDither = bakedLightingEnabled && useDist > 6 && dist <= 12\n                        const useShade = shadeFull || (shadeDither && (x & 1) === 0)\n                        for (let y = top; y < watermark; y++) {\n                            let texY = accum >> 8\n                            if (texY >= 16) texY = 15\n                            let px = cachedTex[(texY << 4) | texX]\n                            if (px) {\n                                if (useShade) px = shadeLUT[px]\n                                if (side == 1 && (x & 1) === 0) px = shadeLUT[px]\n                                col[y] = px\n                            }\n                            accum += stepPerRow\n                        }\n                    }\n                } else {\n                    col.fill(firstBand ? topColor : faceColor, top, watermark - top)\n                }\n                watermark = top\n            }\n            if (topFar < watermark) {\n                col.fill(topColor, topFar, watermark - topFar)\n                watermark = topFar\n            }\n            firstBand = false\n            if (watermark <= 0) { lastDist = dist; break }\n            lastDist = dist\n        }\n\n        colDepth[x] = lastDist\n        bg.setRows(x, col)\n    }\n\n    draw_billboards(bg, sw, sinv, cosv, camX, camZ, camY)\n}\n\nfunction draw_billboards(bg: Image, sw: number, sinv: number, cosv: number, camX: number, camZ: number, camY: number) {\n    const dirX = -sinv, dirZ = -cosv\n    const planeX = -cosv * FOV, planeZ = sinv * FOV\n    const camYVP = camY * VPROJ\n    const invDet = 1 / (planeX * dirZ - dirX * planeZ)\n\n    if (billboardsDirty) {\n        billboards.sort((a, b) => {\n            const dxA = (a.spr.x / 16) - camX, dzA = (a.spr.y / 16) - camZ\n            const dxB = (b.spr.x / 16) - camX, dzB = (b.spr.y / 16) - camZ\n            return (dxB * dxB + dzB * dzB) - (dxA * dxA + dzA * dzA)\n        })\n        billboardsDirty = false\n    }\n\n    for (const bb of billboards) {\n        const bx = bb.spr.x / 16, bz = bb.spr.y / 16, by = bb.worldY\n        const relX = bx - camX, relZ = bz - camZ\n        const tX = invDet * (dirZ * relX - dirX * relZ)\n        const tY = invDet * (-planeZ * relX + planeX * relZ)\n        if (tY <= 0.1) continue\n\n        const img = bb.spr.image\n        const imgW = img.width, imgH = img.height\n\n        const flat: number[] = []\n        for (let fy = 0; fy < imgH; fy++)\n            for (let fx = 0; fx < imgW; fx++)\n                flat[fy * imgW + fx] = img.getPixel(fx, fy)\n\n        const screenXc = (sw / 2) * (1 + tX / tY)\n        const sizeH = (VPROJ * bb.scale / tY) | 0\n        const sizeW = (sizeH * imgW / imgH) | 0\n        if (sizeW <= 0 || sizeH <= 0) continue\n\n        const drawTop = (centerY + (camY - by) * VPROJ / tY) | 0\n        const x0 = (screenXc - sizeW / 2) | 0\n        const shadeSprite = bakedLightingEnabled && tY > 8\n        const shadeAll = tY > 14\n\n        for (let sx = 0; sx < sizeW; sx++) {\n            const screenX = x0 + sx\n            if (screenX < 0 || screenX >= sw) continue\n            if (colDepth[screenX] < tY) continue\n            const texX = (sx * imgW / sizeW) | 0\n            for (let sy = 0; sy < sizeH; sy++) {\n                const screenY = drawTop + sy\n                if (screenY < 0 || screenY >= screenH) continue\n                const texY = (sy * imgH / sizeH) | 0\n                let px = flat[texY * imgW + texX]\n                if (px != 0) {\n                    if (shadeSprite && (shadeAll || ((screenX ^ screenY) & 1) === 0)) {\n                        px = shadeLUT[px]\n                    }\n                    bg.setPixel(screenX, screenY, px)\n                }\n            }\n        }\n    }\n}\n\n// ─── Flow field (BFS from player) ────────────────────────────────────────────\n// Baked once per player-cell-change. Each cell stores which direction (0-3)\n// leads toward the player. Followers do a single array lookup per frame —\n// zero search, zero heap, O(1) steering.\n//\n// Direction encoding: 0=+X  1=-X  2=+Z  3=-Z\n// flowDir[idx] = 255 means unreachable.\n\nconst FF_DX = [1, -1, 0, 0]\nconst FF_DZ = [0, 0, 1, -1]\nconst flowDir: number[] = []      // direction per cell\nconst ffQueue: number[] = []      // flat BFS queue (preallocated)\nlet ffCamCellX = -1\nlet ffCamCellZ = -1\n\nfunction ff_passable(x: number, z: number): number {\n    if (x < 0 || x >= mapWidth || z < 0 || z >= mapHeight) return 0\n    const idx = z * mapWidth + x\n    if (flatIsCollisionWall[idx]) return 0\n    if (flatColorMap[idx] == FLOOR_TRANSPARENT_COLOR) return 0\n    return 1\n}\n\n// BFS flood from (gx,gz) outward, filling flowDir for the whole map.\n// Only runs when the player crosses a grid cell boundary.\nfunction ff_bake(gx: number, gz: number) {\n    const total = mapWidth * mapHeight\n    for (let i = 0; i < total; i++) flowDir[i] = 255\n\n    let head = 0, tail = 0\n    const goalIdx = gz * mapWidth + gx\n    flowDir[goalIdx] = 4   // 4 = \"you are here\"\n    ffQueue[tail++] = goalIdx\n\n    while (head < tail) {\n        const cur = ffQueue[head++]\n        const cx2 = cur % mapWidth\n        const cz2 = (cur / mapWidth) | 0\n        for (let d = 0; d < 4; d++) {\n            const nx = cx2 + FF_DX[d], nz = cz2 + FF_DZ[d]\n            if (!ff_passable(nx, nz)) continue\n            const ni = nz * mapWidth + nx\n            if (flowDir[ni] != 255) continue\n            // store the REVERSE direction so followers know which way to go\n            flowDir[ni] = d ^ 1   // opposite of d: 0<->1, 2<->3\n            ffQueue[tail++] = ni\n        }\n    }\n}\n\n// Call each frame for followers. Returns world-space direction vector\n// packed as dx*100 + 50 in x, dz*100 + 50 in z (avoids returning arrays).\n// Simpler: just steer vx/vz directly here and return 1 if moved, 0 if stuck.\nfunction ff_steer(bb: Billboard, speed: number) {\n    const cx = (bb.spr.x / 16) | 0\n    const cz = (bb.spr.y / 16) | 0\n    const idx = cz * mapWidth + cx\n    const dir = flowDir[idx]\n    if (dir == 255 || dir == 4) return\n    const tx = cx + FF_DX[dir]\n    const tz = cz + FF_DZ[dir]\n    // steer toward center of target cell\n    const wx = bb.spr.x / 16, wz = bb.spr.y / 16\n    const dx = (tx + 0.5) - wx, dz = (tz + 0.5) - wz\n    const d = Math.sqrt(dx * dx + dz * dz)\n    if (d > 0.01) {\n        bb.vx += (dx / d) * 0.04\n        bb.vz += (dz / d) * 0.04\n        const spd = Math.sqrt(bb.vx * bb.vx + bb.vz * bb.vz)\n        if (spd > speed) {\n            bb.vx = bb.vx / spd * speed\n            bb.vz = bb.vz / spd * speed\n        }\n    }\n}\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction update_billboards() {\n    // rebake flow field whenever player moves to a new grid cell\n    const camCellX = cameraX | 0\n    const camCellZ = cameraZ | 0\n    if (camCellX != ffCamCellX || camCellZ != ffCamCellZ) {\n        ffCamCellX = camCellX\n        ffCamCellZ = camCellZ\n        ff_bake(camCellX, camCellZ)\n    }\n\n    for (const bb of billboards) {\n        const hasBob = bb.bobAmp > 0\n        const hasMotion = bb.vx != 0 || bb.vz != 0\n        if (!hasBob && !hasMotion && !bb.follows) continue\n\n        let cx = bb.spr.x / 16\n        let cz = bb.spr.y / 16\n\n        if (bb.follows) {\n            const toCamX = cameraX - cx\n            const toCamZ = cameraZ - cz\n            const toCamDist = Math.sqrt(toCamX * toCamX + toCamZ * toCamZ)\n            if (toCamDist > 1.5) {\n                ff_steer(bb, 0.07)\n            } else {\n                bb.vx *= 0.85\n                bb.vz *= 0.85\n            }\n        }\n\n        const r = 0.3\n        const nextX = cx + bb.vx\n        const padX = bb.vx > 0 ? r : -r\n        if (is_wall(nextX + padX, cz)) bb.vx = -bb.vx\n        else cx = nextX\n        const nextZ = cz + bb.vz\n        const padZ = bb.vz > 0 ? r : -r\n        if (is_wall(cx, nextZ + padZ)) bb.vz = -bb.vz\n        else cz = nextZ\n\n        bb.spr.x = cx * 16\n        bb.spr.y = cz * 16\n\n        if (hasBob) {\n            bb.bobPhase += bb.bobSpeed\n            bb.worldY = bb.bobBaseY + Math.sin(bb.bobPhase) * bb.bobAmp\n        }\n\n        billboardsDirty = true\n    }\n}\n\nlet wobblePhase = 0\nlet isMoving = false\n\ncenterX = scene.screenWidth() * 0.5\ncenterY = scene.screenHeight() * 0.5\nscreenH = scene.screenHeight()\ndepthRows = centerY - 1\ncolumnBuf = control.createBuffer(screenH)\n\nshader = assets.image`shader`\ncolorMap = assets.image`map`\nheightMap = assets.image`height`\nfloorTex = assets.image`lava`\n\nbgImage = scene.backgroundImage()\n\ninit_trig_tables()\ninit_grounded_tiles()\nuse_tilemap_as_data(assets.tilemap`Tilemap Test`)\n\nconst initialLutIndex = cameraAngleDegrees | 0\ncameraCos = cosLUT[initialLutIndex]\ncameraSin = sinLUT[initialLutIndex]\n\nconst coinSpr = sprites.create(img`\n    . . b b b b . .\n    . b 5 5 5 5 b .\n    b 5 d 3 3 d 5 b\n    b 5 3 5 5 1 5 b\n    c 5 3 5 5 1 d c\n    c d d 1 1 d d c\n    . f d d d d f .\n    . . f f f f . .\n`, SpriteKind.Player)\nadd_billboard(coinSpr, mapWidth * 0.5 + 4, mapHeight * 0.5, 8, 4, 0, 0, 1.5, 0.08)\nset_billboard_follows(coinSpr, 1)\nanimation.runImageAnimation(coinSpr, assets.animation`coin`, 100, true)\n\ncontroller.menu.onEvent(ControllerButtonEvent.Pressed, function () {\n    texturing = !texturing\n})\n\nlet titleMode = true\nlet spinAngle = 0\nconst SPIN_RADIUS = 10\nconst SPIN_SPEED = 0.5\nconst MAP_CENTER_X = mapWidth * 0.5\nconst MAP_CENTER_Z = mapHeight * 0.5\n\ncameraMovementEnabled = false\n\ngame.onUpdate(function () {\n    if (!titleMode) return\n    spinAngle = (spinAngle + SPIN_SPEED) % 360\n    const idx = spinAngle | 0\n    cameraX = MAP_CENTER_X + sinLUT[idx] * SPIN_RADIUS\n    cameraZ = MAP_CENTER_Z + cosLUT[idx] * SPIN_RADIUS\n    cameraAngleDegrees = (spinAngle + 0) % 360\n    const li = cameraAngleDegrees | 0\n    cameraCos = cosLUT[li]\n    cameraSin = sinLUT[li]\n    mode_7()\n\n    if (controller.anyButton.isPressed()) {\n        titleMode = false\n        cameraMovementEnabled = true\n        cameraX = MAP_CENTER_X\n        cameraZ = MAP_CENTER_Z\n        cameraY = 6\n        cameraAngleDegrees = 0\n        cameraCos = cosLUT[0]\n        cameraSin = sinLUT[0]\n    }\n})\n\nlet frameCount = 0\ngame.onUpdate(function () {\n    frameCount++\n    update_billboards()\n    if (controller.anyButton.isPressed()) {\n        check_controls()\n        mode_7()\n    } else if (frameCount % 2 == 0) {\n        const li = cameraAngleDegrees | 0\n        cameraCos = cosLUT[li]\n        cameraSin = sinLUT[li]\n        mode_7()\n    }\n})\n\ngame.onPaint(function () {\n    screen.fillRect(0, 0, 46, 24, 15)\n    screen.print(\"X \" + (Math.round(cameraX * 10) / 10), 1, 1, 1, image.font5)\n    screen.print(\"Y \" + (Math.round((cameraY + terrain_height(cameraX, cameraZ)) * 10) / 10), 1, 8, 1, image.font5)\n    screen.print(\"Z \" + (Math.round(cameraZ * 10) / 10), 1, 15, 1, image.font5)\n})","README.md":" ","assets.json":"","images.g.jres":"{\n    \"image4\": {\n        \"data\": \"hwQQABAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA==\",\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"displayName\": \"height2\"\n    },\n    \"image1\": {\n        \"data\": \"\",\n        \"mimeType