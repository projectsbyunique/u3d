: \"image/x-mkcd-f4\",\n        \"tilemapTile\": true,\n        \"displayName\": \"myTile\"\n    },\n    \"tile5\": {\n        \"data\": \"hwQQABAAAAC9nZ29vb29zL2dnb29vb3MvZ2dvb29vcy9nZ29vb29zL2dnb29vb3Mva2dva29vcy9rZq9rbq9zL2tqr2tqr3Mva2qva2qvcy9rZq9rbq9zL2tnb2tvb3MvZ2dvb29vcy9nZ29vb29zL2dnb29vb3MvZ2dvb29vcy9nZ29vb29zA==\",\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"tilemapTile\": true,\n        \"displayName\": \"door\"\n    },\n    \"Floor_Test1\": {\n        \"id\": \"Floor_Test1\",\n        \"mimeType\": \"application/mkcd-tilemap\",\n        \"data\": \"\",\n        \"tileset\": [\n            \"myTiles.transparency16\",\n            \"sprites.castle.tilePath5\"\n        ],\n        \"displayName\": \"Floor_Test\"\n    },\n    \"Ceiling_Test1\": {\n        \"id\": \"Ceiling_Test1\",\n        \"mimeType\": \"application/mkcd-tilemap\",\n        \"data\": \"\",\n        \"tileset\": [\n            \"myTiles.transparency16\",\n            \"sprites.castle.tileGrass1\"\n        ],\n        \"displayName\": \"Ceiling_Test\"\n    },\n    \"level2\": {\n        \"id\": \"level2\",\n        \"mimeType\": \"application/mkcd-tilemap\",\n        \"data\": \"\",\n        \"tileset\": [\n            \"myTiles.transparency16\"\n        ],\n        \"displayName\": \"level2\"\n    },\n    \"level1\": {\n        \"id\": \"level1\",\n        \"mimeType\": \"application/mkcd-tilemap\",\n        \"data\": \"\",\n        \"tileset\": [\n            \"myTiles.transparency16\",\n            \"myTiles.tile1\"\n        ],\n        \"displayName\": \"Tilemap Test\"\n    },\n    \"*\": {\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"dataEncoding\": \"base64\",\n        \"namespace\": \"myTiles\"\n    }\n}","tilemap.g.ts":"","U3D.ts":"//% color=\"#7C3AED\" weight=100 icon=\"\\uf1b2\" block=\"U3D\"\nnamespace U3D {\n    // ─── Configuration ───────────────────────────────────────────────────────\n    const SKY = 12\n    const SHADE_ROW = 1\n    const SHADE_FALLBACK = 15\n    const FOV = 0.88\n    const VPROJ = 25\n    const MAX_STEPS = 64\n    const WALL_HEIGHT = 8\n    const FLOOR_TRANSPARENT_COLOR = 0\n\n    // ─── Camera state ────────────────────────────────────────────────────────\n    let cameraX = 16\n    let cameraY = 6\n    let cameraZ = 16\n    let cameraAngleDegrees = 45\n    let verticalScale = 1.5\n    let texturing = true\n    let cameraMovementEnabled = true\n    let bakedLightingEnabled = true\n    let floorTexturingEnabled = true\n    let viewStepOffset = 0\n\n    let mapWidth = 64\n    let mapHeight = 64\n    let mapXMask = 63          // mapWidth - 1, valid when map is power-of-two\n    let mapZMask = 63\n    let mapPow2 = true         // false => fall back to slow modulo\n    let centerX = 0\n    let centerY = 0\n    let screenH = 0\n    let cachedScreenW = 0    // scene.screenWidth() cached once at start\n    let depthRows = 0\n    let cameraCos = 0\n    let cameraSin = 0\n\n    // ─── Asset references (set via setMaps) ──────────────────────────────────\n    let heightMap: Image = null\n    let colorMap: Image = null\n    let shader: Image = null\n    let floorTex: Image = null\n    let tmData: tiles.TileMapData = null\n    let tileset: Image[] = null\n    let groundedTiles: Image[] = []\n\n    // ─── World data (cached as flat arrays) ──────────────────────────────────\n    const flatHeightMap: number[] = []\n    // Per-cell world-space height overrides. -1 = no override.\n    // Lets you give a tile any decimal height regardless of the heightmap pixel.\n    // Engine reads these every frame, so you can animate them for doors,\n    // moving floors, collapsing platforms, etc.\n    const flatHeightOverride: number[] = []\n    const flatColorMap: number[] = []\n    const flatTileMap: number[] = []\n    const flatIsCollisionWall: boolean[] = []\n    const flatIsGrounded: boolean[] = []\n    const flatTextures: number[][] = []\n    const floorTextureFlat: number[] = []\n\n    let columnBuf: Buffer = null\n   