mimeType\": \"image/x-mkcd-f4\",\n        \"tilemapTile\": true,\n        \"displayName\": \"myTile\"\n    },\n    \"Floor_Test1\": {\n        \"id\": \"Floor_Test1\",\n        \"mimeType\": \"application/mkcd-tilemap\",\n        \"data\": \"\",\n        \"tileset\": [\n            \"myTiles.transparency16\",\n            \"sprites.castle.tilePath5\"\n        ],\n        \"displayName\": \"Floor_Test\"\n    },\n    \"Ceiling_Test1\": {\n        \"id\": \"Ceiling_Test1\",\n        \"mimeType\": \"application/mkcd-tilemap\",\n        \"data\": \"\",\n        \"tileset\": [\n            \"myTiles.transparency16\",\n            \"sprites.castle.tileGrass1\"\n        ],\n        \"displayName\": \"Ceiling_Test\"\n    },\n    \"level2\": {\n        \"id\": \"level2\",\n        \"mimeType\": \"application/mkcd-tilemap\",\n        \"data\": \"\",\n        \"tileset\": [\n            \"myTiles.transparency16\"\n        ],\n        \"displayName\": \"level2\"\n    },\n    \"level1\": {\n        \"id\": \"level1\",\n        \"mimeType\": \"application/mkcd-tilemap\",\n        \"data\": \"\",\n        \"tileset\": [\n            \"myTiles.transparency16\",\n            \"myTiles.tile1\"\n        ],\n        \"displayName\": \"Tilemap Test\"\n    },\n    \"*\": {\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"dataEncoding\": \"base64\",\n        \"namespace\": \"myTiles\"\n    }\n}","tilemap.g.ts":"","U3D.ts":"//% color=\"#7C3AED\" weight=100 icon=\"\\uf1b2\" block=\"U3D\"\nnamespace U3D {\n    // ─── Configuration ───────────────────────────────────────────────────────\n    const SKY = 12\n    const SHADE_ROW = 1\n    const SHADE_FALLBACK = 15\n    const FOV = 0.88\n    const VPROJ = 25\n    const MAX_STEPS = 64\n    const WALL_HEIGHT = 8\n    const FLOOR_TRANSPARENT_COLOR = 0\n\n    // ─── Camera state ────────────────────────────────────────────────────────\n    let cameraX = 16\n    let cameraY = 6\n    let cameraZ = 16\n    let cameraAngleDegrees = 45\n    let verticalScale = 1.5\n    let texturing = true\n    let cameraMovementEnabled = true\n    let bakedLightingEnabled = true\n    let floorTexturingEnabled = true\n    let viewStepOffset = 0\n\n    let mapWidth = 64\n    let mapHeight = 64\n    let mapXMask = 63          // mapWidth - 1, valid when map is power-of-two\n    let mapZMask = 63\n    let mapPow2 = true         // false => fall back to slow modulo\n    let centerX = 0\n    let centerY = 0\n    let screenH = 0\n    let cachedScreenW = 0    // scene.screenWidth() cached once at start\n    let depthRows = 0\n    let cameraCos = 0\n    let cameraSin = 0\n\n    // ─── Asset references (set via setMaps) ──────────────────────────────────\n    let heightMap: Image = null\n    let colorMap: Image = null\n    let shader: Image = null\n    let floorTex: Image = null\n    let tmData: tiles.TileMapData = null\n    let tileset: Image[] = null\n    let groundedTiles: Image[] = []\n\n    // ─── World data (cached as flat arrays) ──────────────────────────────────\n    const flatHeightMap: number[] = []\n    const flatColorMap: number[] = []\n    const flatTileMap: number[] = []\n    const flatIsCollisionWall: boolean[] = []\n    const flatIsGrounded: boolean[] = []\n    const flatTextures: number[][] = []\n    const floorTextureFlat: number[] = []\n\n    let columnBuf: Buffer = null\n    const shadeLUT: number[] = []\n    const shadeLUT2: number[] = []   // shadeLUT applied twice (pre-computed)\n    const colDepth: number[] = []\n    const sinLUT: number[] = []\n    const cosLUT: number[] = []\n    const floorDistLUT: number[] = []   // camYVP / (y - centerY), refreshed per frame\n    let floorShadeStart = 0             // first row (from horizon) where shading kicks in\n\n    let bgImage: Image = null\n\n    // ─── Billboard class ─────────────────────────────────────────────────────\n\n    //% blockId=u3d_billboardflag\n    export enum BillboardFlag {\n        //% block=\"invisible\"\n        Invisible = 1,\n        //% block=\"ghost (clip walls)\"\n        Ghost = 2,\n        //% block=\"terrain tracking\"\n        TerrainTracking = 4\n    }\n\n    export class Billboard {\n        public lastImg: Image = null   // tracks sprite image for flatTex invalidation\n        constructor(\n            public spr: Sprite,\n            public flatTex: number[],\n            public worldY: number,\n            public scale: number,\n            public vx: number,\n            public vz: number,\n            public bobAmp: number,\n            public bobSpeed: number,\n            public bobPhase: number,\n            public bobBaseY: number,\n            public follows: number,\n            public flags: number\n        ) { }\n    }\n    const billboards: Billboard[] = []\n    let billboardsDirty = true\n\n    // ─── Spin-around state ───────────────────────────────────────────────────\n    let spinActive = false\n    let spinAngle = 0\n    let spinCenterX = 0\n    let spinCenterZ = 0\n    let spinRadius = 10\n    let spinSpeed = 0.5\n\n    // ─── Wobble & movement ───────────────────────────────────────────────────\n    let wobblePhase = 0\n    let isMoving = false\n\n    // ─── Internal helpers ────────────────────────────────────────────────────\n    function init_trig_tables() {\n        for (let i = 0; i < 360; i++) {\n            const rad = i * 0.0174532925\n            sinLUT[i] = Math.sin(rad)\n            cosLUT[i] = Math.cos(rad)\n        }\n    }\n\n    function flatten_image(img: Image): number[] {\n        const flat: number[] = []\n        const w = img.width, h = img.height\n        for (let ty = 0; ty < h; ty++) {\n            for (let tx = 0; tx < w; tx++) {\n                flat[ty * w + tx] = img.getPixel(tx, ty)\n            }\n        }\n        return flat\n    }\n\n    function cache_world_data() {\n        if (!heightMap || !colorMap) return\n\n        mapWidth = heightMap.width\n        mapHeight = heightMap.height\n        mapXMask = mapWidth - 1\n        mapZMask = mapHeight - 1\n        // power-of-two test: x & (x-1) == 0\n        mapPow2 = (mapWidth & mapXMask) == 0 && (mapHeight & mapZMask) == 0\n\n        if (shader) {\n            for (let i = 0; i < 16; i++) {\n                const s = shader.getPixel(i, SHADE_ROW)\n                shadeLUT[i] = (s == 0 || s == i) ? SHADE_FALLBACK : s\n            }\n            // Pre-compute double-shaded LUT for the (sometimes shadeLUT applied twice) case\n            for (let i = 0; i < 16; i++) {\n                shadeLUT2[i] = shadeLUT[shadeLUT[i]]\n            }\n        }\n\n        if (floorTex) {\n            const flat = flatten_image(floorTex)\n            for (let i = 0; i < flat.length; i++) floorTextureFlat[i] = flat[i]\n        }\n\n        if (tileset) {\n            for (let i = 0; i < tileset.length; i++) {\n                const tex = tileset[i]\n                const flat: number[] = []\n                flatIsGrounded[i] = false\n                if (tex) {\n                    for (let ty = 0; ty < 16; ty++) {\n                        for (let tx = 0; tx < 16; tx++) {\n                            flat[(ty << 4) | tx] = tex.getPixel(tx, ty)\n                        }\n                    }\n                    for (const g of groundedTiles) {\n                        if (!g) continue\n                        let match = true\n                        for (let py = 0; py < 16 && match; py++) {\n                            for (let px2 = 0; px2 < 16 && match; px2++) {\n                                if (g.getPixel(px2, py) != tex.getPixel(px2, py)) match = false\n                            }\n                        }\n                        if (match) flatIsGrounded[i] = true\n                    }\n                }\n                flatTextures[i] = flat\n            }\n        }\n\n        for (let z = 0; z < mapHeight; z++) {\n            for (let x = 0; x < mapWidth; x++) {\n                const idx = z * mapWidth + x\n                flatHeightMap[idx] = heightM